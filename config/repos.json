{
  "$schema": "repos-config",
  "$comment": "Skill Hub 仓库配置 — 添加/删除仓库只需编辑此文件，无需改 Python 代码",
  "lastUpdated": "2026-06-04",
  "sources": {
    "openai-skills": {
      "repo": "openai/skills",
      "type": "skill_dir",
      "path": "skills/.curated",
      "source": "official",
      "install": "$skill-installer {name}",
      "auto_groups": true
    },
    "anthropic-skills": {
      "repo": "anthropics/skills",
      "type": "skill_dir",
      "path": "skills",
      "source": "claude",
      "install": "$skill-installer {name}",
      "auto_groups": false
    }
  },
  "repos": {
    "ComposioHQ/awesome-codex-skills": {
      "source": "community",
      "name": "awesome-codex-skills",
      "install": "git clone https://github.com/ComposioHQ/awesome-codex-skills.git  # browse the awesome list"
    },
    "VoltAgent/awesome-codex-subagents": {
      "source": "community",
      "name": "awesome-codex-subagents",
